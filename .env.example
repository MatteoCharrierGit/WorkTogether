# Database
DB_NAME=worktogether
DB_USER=wt
DB_PASSWORD=changeme

# JWT
JWT_SECRET=please-change-this-secret-key-in-production-min-32-chars
JWT_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# Admin iniziale (creato al primo avvio se non esiste)
ADMIN_INIT_EMAIL=admin@example.com
ADMIN_INIT_PASSWORD=Admin1234!

# Email (invio per ruoli dall'app). Per Gmail: usa una "app password" Google.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
# Mittente mostrato; di default usa MAIL_USERNAME
MAIL_FROM=

# Frontend: URL base API (lasciare vuoto per uso via nginx proxy)
VITE_API_URL=

# ── Voce / LiveKit (Fase 2) ──────────────────────────────────────────────────
# Lasciare vuoto per tenere la voce disattivata.
# LIVEKIT_URL = URL pubblico WSS che il browser usa per connettersi al media server
#   (es. wss://livekit.tuo-dominio.com). In locale senza TLS: ws://localhost:7880
# LIVEKIT_API_KEY / LIVEKIT_API_SECRET devono combaciare con LIVEKIT_KEYS in docker-compose.
# Il secret deve essere lungo e casuale (min 32 caratteri).
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL=3600
